# Backend presigned URL API (local mock or production endpoint)
PRESIGNED_URL_API=http://10.0.2.2:3001

# AWS credentials (backend only — never ship these in the APK)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=locara-egocam-videos

# Upload config
UPLOAD_MAX_RETRIES=6
UPLOAD_MAX_DURATION_SECONDS=60
